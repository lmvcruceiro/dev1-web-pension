---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Pensión Agro da Porta for bookings, questions, and Camino support.">
  <section class="bg-stone-900 px-4 py-16 text-center sm:px-6 sm:py-24">
    <p class="mb-4 font-lato text-xs uppercase tracking-[0.22em] text-amber-400 sm:tracking-[0.35em]">
      We Are Here To Help
    </p>
    <h1 class="font-playfair text-4xl font-bold text-stone-50 sm:text-5xl md:text-6xl">
      Contact Pensión Agro da Porta
    </h1>
    <p class="mx-auto mt-6 max-w-2xl font-lato text-base leading-relaxed font-light text-stone-300 sm:text-lg">
      Planning your Camino stop? Send us a message and we will help you find the best option for your stay.
    </p>
  </section>

  <section class="bg-stone-50 px-4 py-16 sm:px-6 sm:py-24">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[1.05fr_1fr]">
      <div class="border border-stone-200 bg-white p-6 sm:p-8">
        <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-700 sm:tracking-[0.3em]">Direct Contact</p>
        <h2 class="mt-3 font-playfair text-3xl text-stone-800">Talk To Us</h2>
        <p class="mt-4 font-lato text-sm leading-relaxed font-light text-stone-600">
          We usually reply within the same day. For same-day arrival, please contact us by phone or WhatsApp.
        </p>

        <div class="mt-8 space-y-5">
          <div class="border-l-4 border-amber-400 bg-amber-50 px-4 py-3">
            <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Email</p>
            <a href="mailto:info@agrodaporta.com" class="mt-1 inline-block font-lato text-base text-stone-800 transition-colors hover:text-amber-700">
              info@agrodaporta.com
            </a>
          </div>

          <div class="border-l-4 border-amber-400 bg-amber-50 px-4 py-3">
            <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Phone / WhatsApp</p>
            <a href="tel:+34000000000" class="mt-1 inline-block font-lato text-base text-stone-800 transition-colors hover:text-amber-700">
              +34 000 000 000
            </a>
          </div>

          <div class="border-l-4 border-amber-400 bg-amber-50 px-4 py-3">
            <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Location</p>
            <p class="mt-1 font-lato text-base text-stone-800">Camino de Santiago, Galicia, Spain</p>
          </div>
        </div>

        <div class="mt-8 border border-stone-200 p-4">
          <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Check-in Window</p>
          <p class="mt-2 font-lato text-sm font-light text-stone-700">14:00 - 21:00 (late arrival possible with prior notice)</p>
        </div>
      </div>

      <div class="border border-stone-700 bg-stone-900 p-6 sm:p-8">
        <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-400 sm:tracking-[0.3em]">Quick Inquiry</p>
        <h2 class="mt-3 font-playfair text-3xl text-stone-100">Send A Message</h2>
        <p class="mt-4 font-lato text-sm leading-relaxed font-light text-stone-300">
          Share your dates and group size, and we will get back with availability.
        </p>

        <form class="mt-8 space-y-4" action="#" method="post">
          <div>
            <label for="name" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Full Name</label>
            <input
              id="name"
              name="name"
              type="text"
              class="w-full border border-stone-600 bg-stone-800 px-4 py-3 font-lato text-stone-100 placeholder:text-stone-500 focus:border-amber-400 focus:outline-none"
              placeholder="Your name"
              required
            />
          </div>

          <div>
            <label for="email" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              class="w-full border border-stone-600 bg-stone-800 px-4 py-3 font-lato text-stone-100 placeholder:text-stone-500 focus:border-amber-400 focus:outline-none"
              placeholder="you@example.com"
              required
            />
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label for="arrival" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Arrival</label>
              <input
                id="arrival"
                name="arrival"
                type="date"
                class="w-full border border-stone-600 bg-stone-800 px-4 py-3 font-lato text-stone-100 focus:border-amber-400 focus:outline-none"
              />
            </div>

            <div>
              <label for="guests" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Guests</label>
              <input
                id="guests"
                name="guests"
                type="number"
                min="1"
                max="10"
                class="w-full border border-stone-600 bg-stone-800 px-4 py-3 font-lato text-stone-100 focus:border-amber-400 focus:outline-none"
                placeholder="1"
              />
            </div>
          </div>

          <div>
            <label for="message" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              class="w-full resize-y border border-stone-600 bg-stone-800 px-4 py-3 font-lato text-stone-100 placeholder:text-stone-500 focus:border-amber-400 focus:outline-none"
              placeholder="Tell us your room preference and any special needs..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-amber-400 px-8 py-4 font-lato text-sm font-bold uppercase tracking-[0.14em] text-stone-900 transition-colors hover:bg-amber-300 sm:w-auto sm:tracking-widest"
          >
            Send Inquiry
          </button>
        </form>
      </div>
    </div>
  </section>

  <section class="bg-amber-50 px-4 py-14 sm:px-6 sm:py-16">
    <div class="mx-auto max-w-6xl border border-amber-200 bg-white p-6 text-center sm:p-8">
      <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-700 sm:tracking-[0.3em]">Pilgrim Tip</p>
      <p class="mx-auto mt-3 max-w-3xl font-lato text-sm leading-relaxed font-light text-stone-700 sm:text-base">
        During peak Camino dates, availability can fill quickly. Contact us early to secure your preferred room type.
      </p>
    </div>
  </section>
</BaseLayout>
