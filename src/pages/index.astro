---
import BaseLayout from '../layouts/BaseLayout.astro';
import { mainPageImagePaths } from '../data/mainPageImages';
---

<BaseLayout title="Home" description="Agro da Porta - A warm and welcoming albergue on the Camino de Santiago">

  <!-- HERO SECTION -->
  <section class="relative flex min-h-[82svh] items-center justify-center overflow-hidden bg-[#8b5a3c] md:min-h-[90vh]">
    <!-- Background image -->
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/images/caminho.webp');"
    ></div>

    <!-- Dark overlay for text contrast -->
    <div class="absolute inset-0 bg-gradient-to-br from-stone-950/35 via-stone-900/22 to-amber-950/30"></div>

    <!-- Decorative diagonal line -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-0 left-1/2 w-px h-full bg-amber-400 opacity-10 rotate-12 transform origin-top"></div>
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 mx-auto max-w-4xl px-4 text-center sm:px-6">
      <p class="mb-5 text-xs font-lato font-light uppercase tracking-[0.25em] text-amber-400 sm:mb-6 sm:text-sm sm:tracking-[0.4em] animate-fade-in">
        Camino de Santiago
      </p>
      <h1 class="mb-5 font-playfair text-3xl leading-tight font-bold text-stone-50 sm:text-5xl md:mb-6 md:text-8xl">
        Pensión<br /><span class="text-amber-400 italic">Agro da Porta</span>
      </h1>
      <p class="mx-auto mb-8 max-w-xl font-lato text-sm leading-relaxed font-light text-stone-300 sm:text-base md:text-lg md:mb-10 md:text-xl">
        A warm refuge for pilgrims. Rest, connect, and continue your journey renewed.
      </p>
      <div class="flex flex-col justify-center gap-3 sm:flex-row sm:gap-4">
        <!-- Booking page temporarily disabled -->
        <!--
        <a href="/booking" class="w-full min-h-12 bg-amber-400 px-6 py-3 text-center font-lato text-xs font-bold uppercase tracking-[0.14em] text-stone-900 transition-colors hover:bg-amber-300 sm:px-8 sm:py-4 sm:text-sm sm:tracking-widest">
          Book Your Stay
        </a>
        -->
        <a href="/contact#contact-form" class="w-full min-h-12 bg-amber-400 px-6 py-3 text-center font-lato text-xs font-bold uppercase tracking-[0.14em] text-stone-900 transition-colors hover:bg-amber-300 sm:px-8 sm:py-4 sm:text-sm sm:tracking-widest">
          Contact Us
        </a>
        <a href="/services" class="w-full min-h-12 border border-stone-400 px-6 py-3 text-center font-lato text-xs font-light uppercase tracking-[0.14em] text-stone-200 transition-colors hover:border-amber-400 hover:text-amber-400 sm:px-8 sm:py-4 sm:text-sm sm:tracking-widest">
          Our Services
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2 text-stone-500 md:bottom-8">
      <span class="font-lato text-[11px] uppercase tracking-[0.14em] sm:text-xs sm:tracking-widest">Scroll</span>
      <div class="h-10 w-px bg-gradient-to-b from-stone-500 to-transparent sm:h-12"></div>
    </div>
  </section>

  <!-- WHY US SECTION -->
  <section class="bg-stone-50 px-4 py-16 sm:px-6 sm:py-24">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 text-center sm:mb-16">
        <p class="mb-3 font-lato text-xs uppercase tracking-[0.2em] text-amber-600 sm:tracking-[0.3em]">Why Pilgrims Choose Us</p>
        <h2 class="font-playfair text-3xl text-stone-800 sm:text-4xl">A Home Along the Way</h2>
      </div>

      <div class="mx-auto grid max-w-6xl items-center gap-8 sm:gap-10 lg:grid-cols-2 lg:gap-14">
        <div
          class="relative overflow-hidden border border-stone-300 bg-stone-200"
          data-main-page-carousel
          data-images={JSON.stringify(mainPageImagePaths)}
        >
          <img
            src={mainPageImagePaths[0]}
            alt="Pensión Agro da Porta gallery image"
            class="h-full min-h-[270px] w-full object-cover sm:min-h-[360px]"
            data-carousel-image
            loading="lazy"
          />

          <button
            type="button"
            class="absolute left-3 top-1/2 -translate-y-1/2 bg-stone-900/70 px-3 py-2 text-sm text-stone-50 transition-colors hover:bg-stone-900"
            data-carousel-prev
            aria-label="Previous image"
          >
            ←
          </button>

          <button
            type="button"
            class="absolute right-3 top-1/2 -translate-y-1/2 bg-stone-900/70 px-3 py-2 text-sm text-stone-50 transition-colors hover:bg-stone-900"
            data-carousel-next
            aria-label="Next image"
          >
            →
          </button>

          <p class="absolute bottom-3 right-3 bg-stone-900/70 px-2 py-1 font-lato text-xs text-stone-50">
            <span data-carousel-index>1</span>/{mainPageImagePaths.length}
          </p>
        </div>

        <div>
          <h2 class="font-playfair text-2xl text-stone-800 sm:text-3xl md:text-4xl">A Restful Stop On The Camino</h2>
          <p class="mt-4 font-lato text-xs leading-relaxed font-light text-stone-600 sm:text-sm md:text-base">
            Pensión Agro da Porta is a welcoming stop for pilgrims seeking comfort, calm, and genuine local hospitality.
            We combine practical services with a warm atmosphere, so you can recover from the day and begin the next stage with energy.
          </p>
          <p class="mt-3 font-lato text-xs leading-relaxed font-light text-stone-600 sm:text-sm md:text-base">
            Whether you are walking solo or with friends, our house is designed to make your Camino journey easier,
            from quality rest to helpful guidance about the route ahead.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- QUICK INFO STRIP -->
  <section class="bg-[#8b5a3c] px-4 py-10 text-amber-50 sm:px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <div>
        <p class="text-amber-400 font-playfair text-3xl font-bold">Private Bathroom</p>
        <p class="text-amber-200/80 text-sm uppercase tracking-widest font-lato mt-1">Comfort</p>
      </div>
      <div>
        <p class="text-amber-400 font-playfair text-3xl font-bold">Free Wi-Fi</p>
        <p class="text-amber-200/80 text-sm uppercase tracking-widest font-lato mt-1">Connection</p>
      </div>
      <div>
        <p class="text-amber-400 font-playfair text-3xl font-bold">Camino Francés</p>
        <p class="text-amber-200/80 text-sm uppercase tracking-widest font-lato mt-1">Route</p>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="bg-amber-50 px-4 py-16 sm:px-6 sm:py-24">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 text-center sm:mb-16">
        <p class="mb-3 font-lato text-xs uppercase tracking-[0.2em] text-amber-600 sm:tracking-[0.3em]">Pilgrim Voices</p>
        <h2 class="font-playfair text-3xl text-stone-800 sm:text-4xl">What They Say</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Testimonial 1 -->
        <div class="bg-white p-8 border-l-4 border-amber-400">
          <p class="font-lato text-stone-600 font-light italic leading-relaxed mb-6">
            "The best albergue on the whole Camino. The warmth of the hosts made us feel completely at home after a long day of walking."
          </p>
          <p class="font-playfair text-stone-800 font-semibold">— María G.</p>
          <p class="text-xs text-stone-400 font-lato uppercase tracking-widest mt-1">Pilgrim from Madrid</p>
        </div>

        <!-- Testimonial 2 -->
        <div class="bg-white p-8 border-l-4 border-amber-400">
          <p class="font-lato text-stone-600 font-light italic leading-relaxed mb-6">
            "Clean, affordable, and perfectly located. The breakfast gave me the energy I needed to tackle the next stage. Highly recommend!"
          </p>
          <p class="font-playfair text-stone-800 font-semibold">— Thomas K.</p>
          <p class="text-xs text-stone-400 font-lato uppercase tracking-widest mt-1">Pilgrim from Germany</p>
        </div>

        <!-- Testimonial 3 -->
        <div class="bg-white p-8 border-l-4 border-amber-400">
          <p class="font-lato text-stone-600 font-light italic leading-relaxed mb-6">
            "I've walked the Camino three times and always stay at Pensión Agro da Porta. It feels like coming back to family."
          </p>
          <p class="font-playfair text-stone-800 font-semibold">— Anne-Sophie L.</p>
          <p class="text-xs text-stone-400 font-lato uppercase tracking-widest mt-1">Pilgrim from France</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-[#74462b] px-4 py-16 text-center sm:px-6 sm:py-24">
    <div class="max-w-2xl mx-auto">
      <h2 class="mb-4 font-playfair text-3xl text-amber-50 sm:text-4xl">Ready to Walk?</h2>
      <p class="mb-8 font-lato text-base font-light text-amber-200/80 sm:mb-10 sm:text-lg">Your bed is waiting. Reach out and we'll take care of the rest.</p>
      <a href="/contact#contact-form" class="inline-block w-full bg-amber-400 px-10 py-4 font-lato text-sm font-bold uppercase tracking-[0.14em] text-stone-900 transition-colors hover:bg-amber-300 sm:w-auto sm:tracking-widest">
        Get in Touch
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  const carousels = document.querySelectorAll('[data-main-page-carousel]');

  carousels.forEach((carousel) => {
    const rawImages = carousel.getAttribute('data-images') || '[]';
    const images = JSON.parse(rawImages) as string[];
    const imageElement = carousel.querySelector<HTMLImageElement>('[data-carousel-image]');
    const prevButton = carousel.querySelector<HTMLButtonElement>('[data-carousel-prev]');
    const nextButton = carousel.querySelector<HTMLButtonElement>('[data-carousel-next]');
    const indexElement = carousel.querySelector<HTMLElement>('[data-carousel-index]');

    if (!imageElement || !prevButton || !nextButton || !indexElement || images.length === 0) {
      return;
    }

    let currentIndex = 0;

    const updateSlide = () => {
      imageElement.src = images[currentIndex];
      indexElement.textContent = String(currentIndex + 1);
    };

    prevButton.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      updateSlide();
    });

    nextButton.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % images.length;
      updateSlide();
    });

    if (images.length === 1) {
      prevButton.disabled = true;
      nextButton.disabled = true;
      prevButton.classList.add('cursor-not-allowed', 'opacity-50');
      nextButton.classList.add('cursor-not-allowed', 'opacity-50');
    }
  });
</script>