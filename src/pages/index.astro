---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Agro da Porta - A warm and welcoming albergue on the Camino de Santiago">

  <!-- HERO SECTION -->
  <section class="relative flex min-h-[82svh] items-center justify-center overflow-hidden bg-stone-900 md:min-h-[90vh]">
    <!-- Background image -->
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/images/caminho.webp');"
    ></div>

    <!-- Dark overlay for text contrast -->
    <div class="absolute inset-0 bg-gradient-to-br from-stone-950/80 via-stone-900/65 to-amber-950/70"></div>

    <!-- Decorative diagonal line -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-0 left-1/2 w-px h-full bg-amber-400 opacity-10 rotate-12 transform origin-top"></div>
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 mx-auto max-w-4xl px-4 text-center sm:px-6">
      <p class="mb-5 text-xs font-lato font-light uppercase tracking-[0.25em] text-amber-400 sm:mb-6 sm:text-sm sm:tracking-[0.4em] animate-fade-in">
        Camino de Santiago
      </p>
      <h1 class="mb-5 font-playfair text-4xl leading-tight font-bold text-stone-50 sm:text-6xl md:mb-6 md:text-8xl">
        Pensión<br /><span class="text-amber-400 italic">Agro da Porta</span>
      </h1>
      <p class="mx-auto mb-8 max-w-xl font-lato text-base leading-relaxed font-light text-stone-300 sm:text-lg md:mb-10 md:text-xl">
        A warm refuge for pilgrims. Rest, connect, and continue your journey renewed.
      </p>
      <div class="flex flex-col justify-center gap-3 sm:flex-row sm:gap-4">
        <a href="/contact" class="w-full bg-amber-400 px-8 py-4 text-center font-lato text-sm font-bold uppercase tracking-[0.14em] text-stone-900 transition-colors hover:bg-amber-300 sm:w-auto sm:tracking-widest">
          Book Your Stay
        </a>
        <a href="/services" class="w-full border border-stone-400 px-8 py-4 text-center font-lato text-sm font-light uppercase tracking-[0.14em] text-stone-200 transition-colors hover:border-amber-400 hover:text-amber-400 sm:w-auto sm:tracking-widest">
          Our Services
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2 text-stone-500 md:bottom-8">
      <span class="font-lato text-[11px] uppercase tracking-[0.14em] sm:text-xs sm:tracking-widest">Scroll</span>
      <div class="h-10 w-px bg-gradient-to-b from-stone-500 to-transparent sm:h-12"></div>
    </div>
  </section>

  <!-- WHY US SECTION -->
  <section class="bg-stone-50 px-4 py-16 sm:px-6 sm:py-24">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 text-center sm:mb-16">
        <p class="mb-3 font-lato text-xs uppercase tracking-[0.2em] text-amber-600 sm:tracking-[0.3em]">Why Pilgrims Choose Us</p>
        <h2 class="font-playfair text-3xl text-stone-800 sm:text-4xl">A Home Along the Way</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Feature 1 -->
        <div class="text-center group">
          <div class="w-16 h-16 mx-auto mb-4 bg-amber-50 border border-amber-200 flex items-center justify-center group-hover:bg-amber-400 transition-colors">
            <span class="text-2xl">🛏️</span>
          </div>
          <h3 class="font-playfair text-lg text-stone-800 mb-2">Comfortable Beds</h3>
          <p class="font-lato text-sm text-stone-500 font-light leading-relaxed">Quality bunks and private rooms so you wake up ready for the next stage.</p>
        </div>

        <!-- Feature 2 -->
        <div class="text-center group">
          <div class="w-16 h-16 mx-auto mb-4 bg-amber-50 border border-amber-200 flex items-center justify-center group-hover:bg-amber-400 transition-colors">
            <span class="text-2xl">🍳</span>
          </div>
          <h3 class="font-playfair text-lg text-stone-800 mb-2">Pilgrim Breakfast</h3>
          <p class="font-lato text-sm text-stone-500 font-light leading-relaxed">Start your morning with a hearty traditional breakfast before hitting the trail.</p>
        </div>

        <!-- Feature 3 -->
        <div class="text-center group">
          <div class="w-16 h-16 mx-auto mb-4 bg-amber-50 border border-amber-200 flex items-center justify-center group-hover:bg-amber-400 transition-colors">
            <span class="text-2xl">📍</span>
          </div>
          <h3 class="font-playfair text-lg text-stone-800 mb-2">Prime Location</h3>
          <p class="font-lato text-sm text-stone-500 font-light leading-relaxed">Perfectly positioned on the route — close to everything you need.</p>
        </div>

        <!-- Feature 4 -->
        <div class="text-center group">
          <div class="w-16 h-16 mx-auto mb-4 bg-amber-50 border border-amber-200 flex items-center justify-center group-hover:bg-amber-400 transition-colors">
            <span class="text-2xl">🤝</span>
          </div>
          <h3 class="font-playfair text-lg text-stone-800 mb-2">Pilgrim Community</h3>
          <p class="font-lato text-sm text-stone-500 font-light leading-relaxed">Meet fellow pilgrims and share stories in our warm common areas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- QUICK INFO STRIP -->
  <section class="bg-stone-900 px-4 py-10 text-stone-100 sm:px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <div>
        <p class="text-amber-400 font-playfair text-3xl font-bold">€15</p>
        <p class="text-stone-400 text-sm uppercase tracking-widest font-lato mt-1">Per night from</p>
      </div>
      <div>
        <p class="text-amber-400 font-playfair text-3xl font-bold">Open</p>
        <p class="text-stone-400 text-sm uppercase tracking-widest font-lato mt-1">March — October</p>
      </div>
      <div>
        <p class="text-amber-400 font-playfair text-3xl font-bold">Camino Francés</p>
        <p class="text-stone-400 text-sm uppercase tracking-widest font-lato mt-1">Route</p>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="bg-amber-50 px-4 py-16 sm:px-6 sm:py-24">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 text-center sm:mb-16">
        <p class="mb-3 font-lato text-xs uppercase tracking-[0.2em] text-amber-600 sm:tracking-[0.3em]">Pilgrim Voices</p>
        <h2 class="font-playfair text-3xl text-stone-800 sm:text-4xl">What They Say</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Testimonial 1 -->
        <div class="bg-white p-8 border-l-4 border-amber-400">
          <p class="font-lato text-stone-600 font-light italic leading-relaxed mb-6">
            "The best albergue on the whole Camino. The warmth of the hosts made us feel completely at home after a long day of walking."
          </p>
          <p class="font-playfair text-stone-800 font-semibold">— María G.</p>
          <p class="text-xs text-stone-400 font-lato uppercase tracking-widest mt-1">Pilgrim from Madrid</p>
        </div>

        <!-- Testimonial 2 -->
        <div class="bg-white p-8 border-l-4 border-amber-400">
          <p class="font-lato text-stone-600 font-light italic leading-relaxed mb-6">
            "Clean, affordable, and perfectly located. The breakfast gave me the energy I needed to tackle the next stage. Highly recommend!"
          </p>
          <p class="font-playfair text-stone-800 font-semibold">— Thomas K.</p>
          <p class="text-xs text-stone-400 font-lato uppercase tracking-widest mt-1">Pilgrim from Germany</p>
        </div>

        <!-- Testimonial 3 -->
        <div class="bg-white p-8 border-l-4 border-amber-400">
          <p class="font-lato text-stone-600 font-light italic leading-relaxed mb-6">
            "I've walked the Camino three times and always stay at Pensión Agro da Porta. It feels like coming back to family."
          </p>
          <p class="font-playfair text-stone-800 font-semibold">— Anne-Sophie L.</p>
          <p class="text-xs text-stone-400 font-lato uppercase tracking-widest mt-1">Pilgrim from France</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-stone-800 px-4 py-16 text-center sm:px-6 sm:py-24">
    <div class="max-w-2xl mx-auto">
      <h2 class="mb-4 font-playfair text-3xl text-stone-50 sm:text-4xl">Ready to Walk?</h2>
      <p class="mb-8 font-lato text-base font-light text-stone-400 sm:mb-10 sm:text-lg">Your bed is waiting. Reach out and we'll take care of the rest.</p>
      <a href="/contact" class="inline-block w-full bg-amber-400 px-10 py-4 font-lato text-sm font-bold uppercase tracking-[0.14em] text-stone-900 transition-colors hover:bg-amber-300 sm:w-auto sm:tracking-widest">
        Get in Touch
      </a>
    </div>
  </section>

</BaseLayout>