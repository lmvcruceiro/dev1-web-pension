---
import BaseLayout from '../layouts/BaseLayout.astro';

const doubleRoomImagePaths = [
  '/images/double_room/01_double_room.webp',
  '/images/double_room/02_inside_out_perspective.webp',
];

const twinRoomImagePaths = [
  '/images/twin_room/01_twin_bed.webp',
  '/images/twin_room/02_twin_bed_inside_out_perspective.webp',
  '/images/twin_room/03_bathroom.webp',
];
---

<BaseLayout title="Our Rooms" description="Discover the rooms at Pensión Agro da Porta on the Camino de Santiago">

  <!-- PAGE HEADER -->
  <section class="bg-[#8b5a3c] py-12 px-6 text-center">
    <p class="text-amber-400 uppercase tracking-[0.4em] text-xs font-lato mb-4">Rest & Recover</p>
    <h1 class="font-playfair text-5xl md:text-6xl text-stone-50 font-bold">Our Rooms</h1>
    <p class="text-amber-100/80 font-lato font-light text-lg mt-6 max-w-xl mx-auto leading-relaxed">
      Every pilgrim deserves a good night's sleep. Choose the room that suits you best.
    </p>
  </section>

  <!-- ROOMS SECTION -->
  <section class="py-24 px-6 bg-stone-50">
    <div class="max-w-5xl mx-auto flex flex-col gap-16">

      <!-- ROOM 1: Cama de Matrimonio -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 md:gap-10 items-center">
        <!-- Room Image -->
        {doubleRoomImagePaths.length > 0 ? (
          <div
            class="relative h-48 sm:h-64 md:h-72 overflow-hidden border border-stone-300"
            data-room-carousel
            data-images={JSON.stringify(doubleRoomImagePaths)}
          >
            <img
              src={doubleRoomImagePaths[0]}
              alt="Double Room at Pensión Agro da Porta"
              class="h-full w-full object-cover"
              data-carousel-image
              loading="lazy"
            />

            <button
              type="button"
              class="absolute left-3 top-1/2 -translate-y-1/2 bg-stone-900/70 px-3 py-2 text-sm text-stone-50 transition-colors hover:bg-stone-900"
              data-carousel-prev
              aria-label="Previous Double Room image"
            >
              ←
            </button>

            <button
              type="button"
              class="absolute right-3 top-1/2 -translate-y-1/2 bg-stone-900/70 px-3 py-2 text-sm text-stone-50 transition-colors hover:bg-stone-900"
              data-carousel-next
              aria-label="Next Double Room image"
            >
              →
            </button>

            <p class="absolute bottom-3 right-3 bg-stone-900/70 px-2 py-1 font-lato text-xs text-stone-50">
              <span data-carousel-index>1</span>/{doubleRoomImagePaths.length}
            </p>
          </div>
        ) : (
          <div class="h-72 border border-stone-300 bg-stone-200"></div>
        )}
        <!-- Info -->
        <div>
          <h2 class="font-playfair text-3xl text-stone-800 mb-4">Double Room</h2>
          <p class="font-lato text-stone-500 font-light leading-relaxed mb-6">
            A cosy and intimate room with a 150cm double bed. Perfect for couples walking the Camino together. Includes window with natural light and private storage.
          </p>
          <ul class="flex flex-wrap gap-3 mb-8">
            <li class="bg-amber-50 border border-amber-200 text-amber-800 text-xs font-lato uppercase tracking-widest px-3 py-1">150cm bed</li>
            <li class="bg-amber-50 border border-amber-200 text-amber-800 text-xs font-lato uppercase tracking-widest px-3 py-1">Private room</li>
            <li class="bg-amber-50 border border-amber-200 text-amber-800 text-xs font-lato uppercase tracking-widest px-3 py-1">Natural light</li>
            <li class="bg-amber-50 border border-amber-200 text-amber-800 text-xs font-lato uppercase tracking-widest px-3 py-1">Storage</li>
          </ul>
          <a href="/contact#contact-form" class="inline-block bg-amber-400 text-stone-900 font-lato font-bold uppercase tracking-widest text-sm px-8 py-4 hover:bg-amber-300 transition-colors">
            Book This Room
          </a>
        </div>
      </div>

      <!-- DIVIDER -->
      <div class="border-t border-stone-200"></div>

      <!-- ROOM 3: Habitación Doble -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 md:gap-10 items-center">
        <!-- Room Image -->
        {twinRoomImagePaths.length > 0 ? (
          <div
            class="relative h-48 sm:h-64 md:h-72 overflow-hidden border border-stone-300"
            data-room-carousel
            data-images={JSON.stringify(twinRoomImagePaths)}
          >
            <img
              src={twinRoomImagePaths[0]}
              alt="Twin Room at Pensión Agro da Porta"
              class="h-full w-full object-cover"
              data-carousel-image
              loading="lazy"
            />

            <button
              type="button"
              class="absolute left-3 top-1/2 -translate-y-1/2 bg-stone-900/70 px-3 py-2 text-sm text-stone-50 transition-colors hover:bg-stone-900"
              data-carousel-prev
              aria-label="Previous Twin Room image"
            >
              ←
            </button>

            <button
              type="button"
              class="absolute right-3 top-1/2 -translate-y-1/2 bg-stone-900/70 px-3 py-2 text-sm text-stone-50 transition-colors hover:bg-stone-900"
              data-carousel-next
              aria-label="Next Twin Room image"
            >
              →
            </button>

            <p class="absolute bottom-3 right-3 bg-stone-900/70 px-2 py-1 font-lato text-xs text-stone-50">
              <span data-carousel-index>1</span>/{twinRoomImagePaths.length}
            </p>
          </div>
        ) : (
          <div class="h-72 border border-stone-300 bg-stone-200"></div>
        )}
        <!-- Info -->
        <div>
          <h2 class="font-playfair text-3xl text-stone-800 mb-4">Twin Room</h2>
          <p class="font-lato text-stone-500 font-light leading-relaxed mb-6">
            A spacious room with two 90cm single beds, ideal for friends or two pilgrims sharing. Plenty of space for backpacks, boots and everything the Camino demands.
          </p>
          <ul class="flex flex-wrap gap-3 mb-8">
            <li class="bg-amber-50 border border-amber-200 text-amber-800 text-xs font-lato uppercase tracking-widest px-3 py-1">2 × 90cm beds</li>
            <li class="bg-amber-50 border border-amber-200 text-amber-800 text-xs font-lato uppercase tracking-widest px-3 py-1">Private room</li>
            <li class="bg-amber-50 border border-amber-200 text-amber-800 text-xs font-lato uppercase tracking-widest px-3 py-1">Spacious</li>
            <li class="bg-amber-50 border border-amber-200 text-amber-800 text-xs font-lato uppercase tracking-widest px-3 py-1">Storage</li>
          </ul>
          <a href="/contact#contact-form" class="inline-block bg-amber-400 text-stone-900 font-lato font-bold uppercase tracking-widest text-sm px-8 py-4 hover:bg-amber-300 transition-colors">
            Book This Room
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bg-amber-400 py-16 px-6 text-center">
    <h2 class="font-playfair text-3xl text-stone-900 mb-4">Not sure which room is right for you?</h2>
    <p class="font-lato text-stone-700 font-light mb-8">Get in touch and we'll help you find the perfect fit.</p>
    <a href="/contact#contact-form" class="inline-block min-h-12 bg-stone-900 text-stone-50 font-lato font-bold uppercase tracking-widest text-xs px-6 py-3 hover:bg-stone-700 transition-colors sm:text-sm sm:px-10 sm:py-4">
      Contact Us
    </a>
  </section>

  <script>
    const carousels = document.querySelectorAll('[data-room-carousel]');

    carousels.forEach((carousel) => {
      const rawImages = carousel.getAttribute('data-images') || '[]';
      const images = JSON.parse(rawImages) as string[];
      const imageElement = carousel.querySelector<HTMLImageElement>('[data-carousel-image]');
      const prevButton = carousel.querySelector<HTMLButtonElement>('[data-carousel-prev]');
      const nextButton = carousel.querySelector<HTMLButtonElement>('[data-carousel-next]');
      const indexElement = carousel.querySelector<HTMLElement>('[data-carousel-index]');

      if (!imageElement || !prevButton || !nextButton || !indexElement || images.length === 0) {
        return;
      }

      let currentIndex = 0;

      const updateSlide = () => {
        imageElement.src = images[currentIndex];
        indexElement.textContent = String(currentIndex + 1);
      };

      prevButton.addEventListener('click', () => {
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        updateSlide();
      });

      nextButton.addEventListener('click', () => {
        currentIndex = (currentIndex + 1) % images.length;
        updateSlide();
      });

      if (images.length === 1) {
        prevButton.disabled = true;
        nextButton.disabled = true;
        prevButton.classList.add('cursor-not-allowed', 'opacity-50');
        nextButton.classList.add('cursor-not-allowed', 'opacity-50');
      }
    });
  </script>

</BaseLayout>