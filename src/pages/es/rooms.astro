---
import BaseLayout from '../../layouts/BaseLayout.astro';

const doubleRoomImagePaths = [
  '/images/double_room/01_double_room.webp',
  '/images/double_room/02_inside_out_perspective.webp',
];

const twinRoomImagePaths = [
  '/images/twin_room/01_twin_bed.webp',
  '/images/twin_room/02_twin_bed_inside_out_perspective.webp',
  '/images/twin_room/03_bathroom.webp',
];
---

<BaseLayout lang="es" title="Habitaciones" description="Descubre las habitaciones de Pensión Agro da Porta en el Camino de Santiago">
  <section class="bg-[#8b5a3c] px-6 py-12 text-center">
    <p class="mb-4 font-lato text-xs uppercase tracking-[0.4em] text-amber-400">Descansa y Recupérate</p>
    <h1 class="font-playfair text-5xl font-bold text-stone-50 md:text-6xl">Nuestras Habitaciones</h1>
    <p class="mx-auto mt-6 max-w-xl font-lato text-lg font-light leading-relaxed text-amber-100/80">
      Cada peregrino merece dormir bien. Elige la habitación que mejor se adapta a tu viaje.
    </p>
  </section>

  <section class="bg-stone-50 px-6 py-24">
    <div class="mx-auto flex max-w-5xl flex-col gap-16">
      <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2">
        {doubleRoomImagePaths.length > 0 ? (
          <div
            class="relative h-72 overflow-hidden border border-stone-300"
            data-room-carousel
            data-images={JSON.stringify(doubleRoomImagePaths)}
          >
            <img
              src={doubleRoomImagePaths[0]}
              alt="Habitación de cama de matrimonio en Pensión Agro da Porta"
              class="h-full w-full object-cover"
              data-carousel-image
              loading="lazy"
            />

            <button
              type="button"
              class="absolute left-3 top-1/2 -translate-y-1/2 bg-stone-900/70 px-3 py-2 text-sm text-stone-50 transition-colors hover:bg-stone-900"
              data-carousel-prev
              aria-label="Imagen anterior de habitación doble"
            >
              ←
            </button>

            <button
              type="button"
              class="absolute right-3 top-1/2 -translate-y-1/2 bg-stone-900/70 px-3 py-2 text-sm text-stone-50 transition-colors hover:bg-stone-900"
              data-carousel-next
              aria-label="Siguiente imagen de habitación doble"
            >
              →
            </button>

            <p class="absolute bottom-3 right-3 bg-stone-900/70 px-2 py-1 font-lato text-xs text-stone-50">
              <span data-carousel-index>1</span>/{doubleRoomImagePaths.length}
            </p>
          </div>
        ) : (
          <div class="h-72 border border-stone-300 bg-stone-200"></div>
        )}

        <div>
          <h2 class="mb-4 font-playfair text-3xl text-stone-800">Habitación con Cama de Matrimonio</h2>
          <p class="mb-6 font-lato font-light leading-relaxed text-stone-500">
            Un espacio acogedor con cama de 150 cm, ideal para parejas que hacen el Camino juntas. Incluye luz natural y almacenaje privado.
          </p>
          <ul class="mb-8 flex flex-wrap gap-3">
            <li class="border border-amber-200 bg-amber-50 px-3 py-1 font-lato text-xs uppercase tracking-widest text-amber-800">Cama de 150 cm</li>
            <li class="border border-amber-200 bg-amber-50 px-3 py-1 font-lato text-xs uppercase tracking-widest text-amber-800">Habitación privada</li>
            <li class="border border-amber-200 bg-amber-50 px-3 py-1 font-lato text-xs uppercase tracking-widest text-amber-800">Luz natural</li>
            <li class="border border-amber-200 bg-amber-50 px-3 py-1 font-lato text-xs uppercase tracking-widest text-amber-800">Almacenaje</li>
          </ul>
          <a href="/es/contact#contact-form" class="inline-block bg-amber-400 px-8 py-4 font-lato text-sm font-bold uppercase tracking-widest text-stone-900 transition-colors hover:bg-amber-300">
            Reservar Esta Habitación
          </a>
        </div>
      </div>

      <div class="border-t border-stone-200"></div>

      <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2">
        {twinRoomImagePaths.length > 0 ? (
          <div
            class="relative h-72 overflow-hidden border border-stone-300"
            data-room-carousel
            data-images={JSON.stringify(twinRoomImagePaths)}
          >
            <img
              src={twinRoomImagePaths[0]}
              alt="Habitación con dos camas en Pensión Agro da Porta"
              class="h-full w-full object-cover"
              data-carousel-image
              loading="lazy"
            />

            <button
              type="button"
              class="absolute left-3 top-1/2 -translate-y-1/2 bg-stone-900/70 px-3 py-2 text-sm text-stone-50 transition-colors hover:bg-stone-900"
              data-carousel-prev
              aria-label="Imagen anterior de habitación twin"
            >
              ←
            </button>

            <button
              type="button"
              class="absolute right-3 top-1/2 -translate-y-1/2 bg-stone-900/70 px-3 py-2 text-sm text-stone-50 transition-colors hover:bg-stone-900"
              data-carousel-next
              aria-label="Siguiente imagen de habitación twin"
            >
              →
            </button>

            <p class="absolute bottom-3 right-3 bg-stone-900/70 px-2 py-1 font-lato text-xs text-stone-50">
              <span data-carousel-index>1</span>/{twinRoomImagePaths.length}
            </p>
          </div>
        ) : (
          <div class="h-72 border border-stone-300 bg-stone-200"></div>
        )}

        <div>
          <h2 class="mb-4 font-playfair text-3xl text-stone-800">Habitación Doble con Camas Individuales</h2>
          <p class="mb-6 font-lato font-light leading-relaxed text-stone-500">
            Habitación amplia con dos camas de 90 cm, perfecta para amigos o peregrinos que comparten. Espacio cómodo para mochilas y equipaje.
          </p>
          <ul class="mb-8 flex flex-wrap gap-3">
            <li class="border border-amber-200 bg-amber-50 px-3 py-1 font-lato text-xs uppercase tracking-widest text-amber-800">2 x camas de 90 cm</li>
            <li class="border border-amber-200 bg-amber-50 px-3 py-1 font-lato text-xs uppercase tracking-widest text-amber-800">Habitación privada</li>
            <li class="border border-amber-200 bg-amber-50 px-3 py-1 font-lato text-xs uppercase tracking-widest text-amber-800">Espaciosa</li>
            <li class="border border-amber-200 bg-amber-50 px-3 py-1 font-lato text-xs uppercase tracking-widest text-amber-800">Almacenaje</li>
          </ul>
          <a href="/es/contact#contact-form" class="inline-block bg-amber-400 px-8 py-4 font-lato text-sm font-bold uppercase tracking-widest text-stone-900 transition-colors hover:bg-amber-300">
            Reservar Esta Habitación
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-amber-400 px-6 py-16 text-center">
    <h2 class="mb-4 font-playfair text-3xl text-stone-900">No sabes qué habitación elegir?</h2>
    <p class="mb-8 font-lato font-light text-stone-700">Escríbenos y te ayudaremos a encontrar la mejor opción para ti.</p>
    <a href="/es/contact#contact-form" class="inline-block bg-stone-900 px-10 py-4 font-lato text-sm font-bold uppercase tracking-widest text-stone-50 transition-colors hover:bg-stone-700">
      Contactar
    </a>
  </section>

  <script>
    const carousels = document.querySelectorAll('[data-room-carousel]');

    carousels.forEach((carousel) => {
      const rawImages = carousel.getAttribute('data-images') || '[]';
      const images = JSON.parse(rawImages) as string[];
      const imageElement = carousel.querySelector<HTMLImageElement>('[data-carousel-image]');
      const prevButton = carousel.querySelector<HTMLButtonElement>('[data-carousel-prev]');
      const nextButton = carousel.querySelector<HTMLButtonElement>('[data-carousel-next]');
      const indexElement = carousel.querySelector<HTMLElement>('[data-carousel-index]');

      if (!imageElement || !prevButton || !nextButton || !indexElement || images.length === 0) {
        return;
      }

      let currentIndex = 0;

      const updateSlide = () => {
        imageElement.src = images[currentIndex];
        indexElement.textContent = String(currentIndex + 1);
      };

      prevButton.addEventListener('click', () => {
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        updateSlide();
      });

      nextButton.addEventListener('click', () => {
        currentIndex = (currentIndex + 1) % images.length;
        updateSlide();
      });

      if (images.length === 1) {
        prevButton.disabled = true;
        nextButton.disabled = true;
        prevButton.classList.add('cursor-not-allowed', 'opacity-50');
        nextButton.classList.add('cursor-not-allowed', 'opacity-50');
      }
    });
  </script>
</BaseLayout>
