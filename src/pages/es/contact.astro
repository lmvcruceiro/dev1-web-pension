---
import BaseLayout from '../../layouts/BaseLayout.astro';

const formEndpoint = 'https://formsubmit.co/ajax/infoagrodaporta@gmail.com';
---

<BaseLayout lang="es" title="Contacto" description="Ponte en contacto con Pensión Agro da Porta para reservas, dudas y ayuda en tu Camino.">
  <section class="bg-[#8b5a3c] px-4 py-10 text-center sm:px-6 sm:py-14">
    <p class="mb-4 font-lato text-xs uppercase tracking-[0.22em] text-amber-400 sm:tracking-[0.35em]">
      Estamos Para Ayudarte
    </p>
    <h1 class="font-playfair text-4xl font-bold text-stone-50 sm:text-5xl md:text-6xl">
      Contacta Con Pensión Agro da Porta
    </h1>
    <p class="mx-auto mt-6 max-w-2xl font-lato text-base leading-relaxed font-light text-amber-100/80 sm:text-lg">
      Estás organizando tu parada en el Camino? Envíanos tu consulta y te ayudaremos a elegir la mejor opción de estancia.
    </p>
  </section>

  <section class="bg-stone-50 px-4 py-16 sm:px-6 sm:py-24">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[1.05fr_1fr]">
      <div class="border border-stone-200 bg-white p-6 sm:p-8">
        <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-700 sm:tracking-[0.3em]">Contacto Directo</p>
        <h2 class="mt-3 font-playfair text-3xl text-stone-800">Hablemos</h2>
        <p class="mt-4 font-lato text-sm leading-relaxed font-light text-stone-600">
          Normalmente respondemos el mismo día. Para llegadas en el mismo día, te recomendamos llamar o escribir por WhatsApp.
        </p>

        <div class="mt-8 space-y-5">
          <div class="border-l-4 border-amber-400 bg-amber-50 px-4 py-3">
            <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Correo</p>
            <a href="mailto:infoagrodaporta@gmail.com" class="mt-1 inline-block font-lato text-base text-stone-800 transition-colors hover:text-amber-700">
              infoagrodaporta@gmail.com
            </a>
          </div>

          <div class="border-l-4 border-amber-400 bg-amber-50 px-4 py-3">
            <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Teléfono / WhatsApp</p>
            <a href="tel:+34744251454" class="mt-1 inline-block font-lato text-base text-stone-800 transition-colors hover:text-amber-700">
              +34 744 25 14 54
            </a>
          </div>

          <div class="border-l-4 border-amber-400 bg-amber-50 px-4 py-3">
            <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Ubicación</p>
            <p class="mt-1 font-lato text-base text-stone-800">Palas de Rei, Galicia, España</p>
          </div>
        </div>

        <div class="mt-8 border border-stone-200 p-4">
          <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Horario De Check-in</p>
          <p class="mt-2 font-lato text-sm font-light text-stone-700">11:00 - 16:30 (llegada tarde posible con aviso previo)</p>
        </div>
      </div>

      <div id="contact-form" class="scroll-mt-24 border border-[#5f3a24] bg-[#74462b] p-6 sm:p-8">
        <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-400 sm:tracking-[0.3em]">Consulta Rápida</p>
        <h2 class="mt-3 font-playfair text-3xl text-stone-100">Envíanos Un Mensaje</h2>
        <p class="mt-4 font-lato text-sm leading-relaxed font-light text-stone-300">
          Indícanos tus fechas y número de personas y te responderemos con disponibilidad.
        </p>

        <div
          class="mt-6 hidden border border-emerald-300/40 bg-emerald-500/10 px-4 py-3 font-lato text-sm text-emerald-100"
          data-contact-success
          role="status"
          aria-live="polite"
        >
          Tu correo se ha enviado correctamente al alojamiento en infoagrodaporta@gmail.com. Te responderemos lo antes posible.
        </div>

        <div
          class="mt-6 hidden border border-rose-300/40 bg-rose-500/10 px-4 py-3 font-lato text-sm text-rose-100"
          data-contact-error
          role="alert"
        >
          No hemos podido enviar tu mensaje ahora mismo. Inténtalo de nuevo o escribe directamente a infoagrodaporta@gmail.com.
        </div>

        <form class="mt-8 space-y-4" action={formEndpoint} method="post" data-contact-form>
          <input type="hidden" name="_subject" value="Nueva consulta desde la web de Pensión Agro da Porta" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div>
            <label for="name" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Nombre Completo</label>
            <input
              id="name"
              name="name"
              type="text"
              class="w-full border border-stone-600 bg-stone-800 px-4 py-3 font-lato text-stone-100 placeholder:text-stone-500 focus:border-amber-400 focus:outline-none"
              placeholder="Tu nombre"
              required
            />
          </div>

          <div>
            <label for="email" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Correo</label>
            <input
              id="email"
              name="email"
              type="email"
              class="w-full border border-stone-600 bg-stone-800 px-4 py-3 font-lato text-stone-100 placeholder:text-stone-500 focus:border-amber-400 focus:outline-none"
              placeholder="tu@email.com"
              required
            />
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label for="arrival" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Llegada</label>
              <input
                id="arrival"
                name="arrival"
                type="date"
                class="w-full border border-stone-600 bg-stone-800 px-4 py-3 font-lato text-stone-100 focus:border-amber-400 focus:outline-none"
              />
            </div>

            <div>
              <label for="guests" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Huéspedes</label>
              <input
                id="guests"
                name="guests"
                type="number"
                min="1"
                max="10"
                value="1"
                class="w-full border border-stone-600 bg-stone-800 px-4 py-3 font-lato text-stone-100 focus:border-amber-400 focus:outline-none"
              />
            </div>
          </div>

          <div>
            <label for="message" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Mensaje</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              class="w-full resize-y border border-stone-600 bg-stone-800 px-4 py-3 font-lato text-stone-100 placeholder:text-stone-500 focus:border-amber-400 focus:outline-none"
              placeholder="Cuéntanos tu preferencia de habitación y cualquier necesidad especial..."
            ></textarea>
          </div>

          <button
            type="submit"
            data-contact-submit
            class="w-full bg-amber-400 px-8 py-4 font-lato text-sm font-bold uppercase tracking-[0.14em] text-stone-900 transition-colors hover:bg-amber-300 sm:w-auto sm:tracking-widest"
          >
            Enviar Consulta
          </button>
        </form>
      </div>
    </div>
  </section>

  <section class="bg-amber-50 px-4 py-14 sm:px-6 sm:py-16">
    <div class="mx-auto max-w-6xl border border-amber-200 bg-white p-6 text-center sm:p-8">
      <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-700 sm:tracking-[0.3em]">Consejo Peregrino</p>
      <p class="mx-auto mt-3 max-w-3xl font-lato text-sm leading-relaxed font-light text-stone-700 sm:text-base">
        En fechas de alta demanda del Camino, la disponibilidad se completa rápido. Escríbenos con antelación para asegurar el tipo de habitación que prefieres.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const contactForms = document.querySelectorAll<HTMLFormElement>('[data-contact-form]');

  contactForms.forEach((form) => {
    const successMessage = form.parentElement?.querySelector<HTMLElement>('[data-contact-success]');
    const errorMessage = form.parentElement?.querySelector<HTMLElement>('[data-contact-error]');
    const submitButton = form.querySelector<HTMLButtonElement>('[data-contact-submit]');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      successMessage?.classList.add('hidden');
      errorMessage?.classList.add('hidden');

      if (submitButton) {
        submitButton.disabled = true;
        submitButton.classList.add('cursor-not-allowed', 'opacity-60');
        submitButton.textContent = 'Enviando...';
      }

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: {
            Accept: 'application/json',
          },
        });

        if (!response.ok) {
          throw new Error('Request failed');
        }

        form.reset();
        successMessage?.classList.remove('hidden');
      } catch {
        errorMessage?.classList.remove('hidden');
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.classList.remove('cursor-not-allowed', 'opacity-60');
          submitButton.textContent = 'Enviar Consulta';
        }
      }
    });
  });
</script>
