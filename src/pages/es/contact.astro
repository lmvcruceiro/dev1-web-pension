---
import BaseLayout from '../../layouts/BaseLayout.astro';

const formEndpoint = 'https://formsubmit.co/ajax/infoagrodaporta@gmail.com';
const whatsappUrl = 'https://wa.me/34744251454';
---

<BaseLayout lang="es" title="Contacto Pensión en Palas de Rei" description="Contacta con nuestro alojamiento para peregrinos en Palas de Rei, en el Camino de Santiago, para disponibilidad y reservas directas.">
  <section class="bg-[#8b5a3c] px-4 py-10 text-center sm:px-6 sm:py-14">
    <p class="mb-4 font-lato text-xs uppercase tracking-[0.22em] text-amber-400 sm:tracking-[0.35em]">
      Estamos Para Ayudarte
    </p>
    <h1 class="font-playfair text-4xl font-bold text-stone-50 sm:text-5xl md:text-6xl">
      Contacta Con Pensión Agro da Porta
    </h1>
    <p class="mx-auto mt-6 max-w-2xl font-lato text-base leading-relaxed font-light text-amber-100/80 sm:text-lg">
      Estás organizando tu parada en el Camino? Envíanos tu consulta y te ayudaremos a elegir la mejor opción de estancia.
    </p>
  </section>

  <section class="bg-stone-50 px-4 py-16 sm:px-6 sm:py-24">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[1.05fr_1fr]">
      <div class="border border-stone-200 bg-white p-6 sm:p-8">
        <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-700 sm:tracking-[0.3em]">Contacto Directo</p>
        <h2 class="mt-3 font-playfair text-3xl text-stone-800">Hablemos</h2>
        <p class="mt-4 font-lato text-sm leading-relaxed font-light text-stone-600">
          Normalmente respondemos el mismo día. Para llegadas en el mismo día, te recomendamos llamar o escribir por WhatsApp.
        </p>

        <div class="mt-8 space-y-5">
          <div class="border-l-4 border-amber-400 bg-amber-50 px-4 py-3">
            <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Correo</p>
            <a href="mailto:infoagrodaporta@gmail.com" class="mt-1 inline-flex items-center gap-2 font-lato text-base text-stone-800 transition-colors hover:text-amber-700">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M2.94 5.5A2 2 0 014.86 4h10.28a2 2 0 011.92 1.5L10 9.88 2.94 5.5z"/>
                <path d="M2.5 7.14V14a2 2 0 002 2h11a2 2 0 002-2V7.14l-6.94 4.31a1 1 0 01-1.06 0L2.5 7.14z"/>
              </svg>
              <span>infoagrodaporta@gmail.com</span>
            </a>
          </div>

          <div class="border-l-4 border-amber-400 bg-amber-50 px-4 py-3">
            <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Teléfono</p>
            <a href="tel:+34744251454" class="mt-1 inline-flex items-center gap-2 font-lato text-base text-stone-800 transition-colors hover:text-amber-700">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M2.7 3.7a1 1 0 011-.7h2.1a1 1 0 01.97.76l.54 2.17a1 1 0 01-.29.98L6.24 8.7a11.05 11.05 0 005.06 5.06l1.76-1.76a1 1 0 01.98-.29l2.17.54a1 1 0 01.76.97v2.1a1 1 0 01-.7 1 4 4 0 01-1.28.18C8.72 16.5 3.5 11.28 3.5 4.98c0-.44.06-.87.2-1.28z"/>
              </svg>
              <span>+34 744 25 14 54</span>
            </a>
          </div>

          <div class="border-l-4 border-amber-400 bg-amber-50 px-4 py-3">
            <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">WhatsApp</p>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Abrir chat por WhatsApp"
              class="mt-1 flex w-fit items-center gap-2 font-lato text-base text-stone-800 transition-colors hover:text-amber-700"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true">
                <path d="M12 2a10 10 0 00-8.7 14.93L2 22l5.22-1.27A10 10 0 1012 2zm0 18a8 8 0 01-4.07-1.11l-.29-.17-3.1.75.83-3.02-.19-.31A8 8 0 1112 20zm4.39-5.61c-.24-.12-1.43-.71-1.65-.79-.22-.08-.38-.12-.54.12-.16.24-.62.79-.76.95-.14.16-.28.18-.52.06-.24-.12-1.02-.38-1.95-1.2-.72-.64-1.2-1.43-1.34-1.67-.14-.24-.01-.37.11-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.2-.47-.4-.41-.54-.42h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.31.98 2.47c.12.16 1.69 2.58 4.1 3.62.57.25 1.02.4 1.37.51.58.18 1.11.15 1.53.09.47-.07 1.43-.58 1.63-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28z"/>
              </svg>
              Abrir WhatsApp
            </a>
          </div>

        </div>

        <div class="mt-8 border border-stone-200 p-4">
          <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Horario De Check-in</p>
          <p class="mt-2 font-lato text-sm font-light text-stone-700">13:00h - 17:00h (se admiten llegadas más tarde con previo aviso)</p>
        </div>
      </div>

      <div id="contact-form" class="scroll-mt-24 border border-[#5f3a24] bg-[#74462b] p-6 sm:p-8">
        <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-400 sm:tracking-[0.3em]">Consulta Rápida</p>
        <h2 class="mt-3 font-playfair text-3xl text-stone-100">Envíanos Un Mensaje</h2>
        <p class="mt-4 font-lato text-sm leading-relaxed font-light text-stone-300">
          Indícanos tus fechas y número de personas y te responderemos con disponibilidad.
        </p>

        <div
          class="mt-6 hidden border border-emerald-300/40 bg-emerald-500/10 px-4 py-3 font-lato text-sm text-emerald-100"
          data-contact-success
          role="status"
          aria-live="polite"
        >
          Tu correo se ha enviado correctamente al alojamiento en infoagrodaporta@gmail.com. Te responderemos lo antes posible.
        </div>

        <div
          class="mt-6 hidden border border-rose-300/40 bg-rose-500/10 px-4 py-3 font-lato text-sm text-rose-100"
          data-contact-error
          role="alert"
        >
          No hemos podido enviar tu mensaje ahora mismo. Inténtalo de nuevo o escribe directamente a infoagrodaporta@gmail.com.
        </div>

        <form class="mt-8 space-y-4" action={formEndpoint} method="post" data-contact-form>
          <input type="hidden" name="_subject" value="Nueva consulta desde la web de Pensión Agro da Porta" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div>
            <label for="name" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Nombre Completo</label>
            <input
              id="name"
              name="name"
              type="text"
              class="w-full min-h-10 border border-stone-600 bg-stone-800 px-3 py-2 font-lato text-sm text-stone-100 placeholder:text-stone-500 focus:border-amber-400 focus:outline-none sm:px-4 sm:py-3"
              placeholder="Tu nombre"
              required
            />
          </div>

          <div>
            <label for="email" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Correo</label>
            <input
              id="email"
              name="email"
              type="email"
              class="w-full min-h-10 border border-stone-600 bg-stone-800 px-3 py-2 font-lato text-sm text-stone-100 placeholder:text-stone-500 focus:border-amber-400 focus:outline-none sm:px-4 sm:py-3"
              placeholder="tu@email.com"
              required
            />
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label for="arrival" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Llegada</label>
              <input
                id="arrival"
                name="arrival"
                type="date"
                class="w-full min-h-10 border border-stone-600 bg-stone-800 px-3 py-2 font-lato text-sm text-stone-100 focus:border-amber-400 focus:outline-none sm:px-4 sm:py-3"
              />
            </div>

            <div>
              <label for="guests" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Huéspedes</label>
              <input
                id="guests"
                name="guests"
                type="number"
                min="1"
                max="10"
                value="1"
                class="w-full min-h-10 border border-stone-600 bg-stone-800 px-3 py-2 font-lato text-sm text-stone-100 focus:border-amber-400 focus:outline-none sm:px-4 sm:py-3"
              />
            </div>
          </div>

          <div>
            <label for="message" class="mb-2 block font-lato text-xs uppercase tracking-[0.12em] text-stone-400">Mensaje</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full min-h-24 resize-y border border-stone-600 bg-stone-800 px-3 py-2 font-lato text-sm text-stone-100 placeholder:text-stone-500 focus:border-amber-400 focus:outline-none sm:px-4 sm:py-3 sm:min-h-32 sm:rows-5"
              placeholder="Cuéntanos tu preferencia de habitación y cualquier necesidad especial..."
            ></textarea>
          </div>

          <button
            type="submit"
            data-contact-submit
            class="w-full min-h-12 bg-amber-400 px-6 py-3 font-lato text-xs font-bold uppercase tracking-[0.14em] text-stone-900 transition-colors hover:bg-amber-300 sm:w-auto sm:px-8 sm:py-4 sm:text-sm sm:tracking-widest"
          >
            Enviar Consulta
          </button>
        </form>
      </div>
    </div>
  </section>

  <section class="bg-stone-50 px-4 py-14 sm:px-6 sm:py-16">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 text-center sm:mb-12">
        <p class="mb-3 font-lato text-xs uppercase tracking-[0.2em] text-amber-600 sm:tracking-[0.3em]">Ubicación</p>
        <h2 class="font-playfair text-3xl text-stone-800 sm:text-4xl">Cómo Encontrarnos</h2>
      </div>

      <div class="border border-amber-200 bg-white p-6 text-center sm:p-8">
        <p class="font-lato text-xs uppercase tracking-[0.14em] text-stone-500">Dirección</p>
        <p class="mt-3 font-lato text-base font-light leading-relaxed text-stone-700 sm:text-lg">
          <span class="block">Pensión Agro da Porta</span>
          <span class="block">Rúa Cruceiro 13</span>
          <span class="block">Palas de Rei (Lugo), Spain</span>
        </p>
        <a
          href="https://www.google.com/maps/place/Pensi%C3%B3n+Agro+da+Porta/@42.873017,-7.8671399,20z/data=!4m15!1m5!3m4!2zNDLCsDUyJzIyLjkiTiA3wrA1MicwMC41Ilc!8m2!3d42.873017!4d-7.866818!3m8!1s0xd2fd54482ef9e57:0x3496ffaddd4bf814!5m2!4m1!1i2!8m2!3d42.8729849!4d-7.8668177!16s%2Fg%2F11z9rsflnv?entry=ttu&amp;g_ep=EgoyMDI2MDQyOS4wIKXMDSoASAFQAw%3D%3D"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex min-h-12 items-center justify-center gap-2 bg-amber-400 px-6 py-3 font-lato text-xs font-bold uppercase tracking-[0.14em] text-stone-900 transition-colors hover:bg-amber-300 sm:px-8 sm:py-4 sm:text-sm sm:tracking-widest"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M10 2a6 6 0 00-6 6c0 4.79 5.23 9.48 5.45 9.68a.75.75 0 001.1 0C10.77 17.48 16 12.79 16 8a6 6 0 00-6-6zm0 8.5A2.5 2.5 0 1112.5 8 2.5 2.5 0 0110 10.5z"/>
          </svg>
          Obtener Indicaciones
        </a>
      </div>
    </div>
  </section>

  <section class="bg-amber-50 px-4 py-14 sm:px-6 sm:py-16">
    <div class="mx-auto max-w-6xl border border-amber-200 bg-white p-6 text-center sm:p-8">
      <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-700 sm:tracking-[0.3em]">Consejo Peregrino</p>
      <p class="mx-auto mt-3 max-w-3xl font-lato text-sm leading-relaxed font-light text-stone-700 sm:text-base">
        En fechas de alta demanda del Camino, la disponibilidad se completa rápido. Escríbenos con antelación para asegurar el tipo de habitación que prefieres.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const contactForms = document.querySelectorAll<HTMLFormElement>('[data-contact-form]');

  contactForms.forEach((form) => {
    const successMessage = form.parentElement?.querySelector<HTMLElement>('[data-contact-success]');
    const errorMessage = form.parentElement?.querySelector<HTMLElement>('[data-contact-error]');
    const submitButton = form.querySelector<HTMLButtonElement>('[data-contact-submit]');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      successMessage?.classList.add('hidden');
      errorMessage?.classList.add('hidden');

      if (submitButton) {
        submitButton.disabled = true;
        submitButton.classList.add('cursor-not-allowed', 'opacity-60');
        submitButton.textContent = 'Enviando...';
      }

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: {
            Accept: 'application/json',
          },
        });

        if (!response.ok) {
          throw new Error('Request failed');
        }

        form.reset();
        successMessage?.classList.remove('hidden');
      } catch {
        errorMessage?.classList.remove('hidden');
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.classList.remove('cursor-not-allowed', 'opacity-60');
          submitButton.textContent = 'Enviar Consulta';
        }
      }
    });
  });
</script>
