---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services" description="Discover everything we offer at Pensión Agro da Porta for a comfortable Camino stop.">
  <section class="bg-[#8b5a3c] px-4 py-10 text-center sm:px-6 sm:py-14">
    <p class="mb-4 font-lato text-xs uppercase tracking-[0.22em] text-amber-400 sm:tracking-[0.35em]">
      Camino Comfort
    </p>
    <h1 class="font-playfair text-4xl font-bold text-stone-50 sm:text-5xl md:text-6xl">
      Services For Pilgrims
    </h1>
    <p class="mx-auto mt-6 max-w-2xl font-lato text-base leading-relaxed font-light text-amber-100/80 sm:text-lg">
      Thoughtful essentials, warm hospitality, and practical support designed for walkers who need to rest well and keep moving.
    </p>
  </section>

  <section class="bg-stone-50 px-4 py-16 sm:px-6 sm:py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12 text-center sm:mb-16">
        <p class="mb-3 font-lato text-xs uppercase tracking-[0.2em] text-amber-600 sm:tracking-[0.3em]">What We Offer</p>
        <h2 class="font-playfair text-3xl text-stone-800 sm:text-4xl">Everything You Need, Nothing You Don't</h2>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16 lg:items-start">
        <div class="order-1">
          <p class="mb-3 font-lato text-xs uppercase tracking-[0.2em] text-amber-600 sm:tracking-[0.3em]">Why Choose Us</p>
          <h3 class="mb-6 font-playfair text-2xl text-stone-800 sm:text-3xl">Your Place to Rest</h3>
          <p class="mb-8 font-lato text-base leading-relaxed font-light text-stone-600 sm:text-lg">
            At Pensión Agro da Porta, we believe that exceptional accommodation enhances your entire Camino experience. Our thoughtfully curated services—from individual climate control to our peaceful garden, from modern Smart TV entertainment to accessible facilities—are designed with you in mind. Whether you cycle the route, travel solo, or walk with mobility considerations, we've got everything you need for rest, connection, and comfort.
          </p>
          <div class="relative overflow-hidden rounded-lg border border-stone-200 shadow-sm" data-carousel>
            <div class="flex transition-transform duration-500 ease-in-out" data-carousel-track>
              <img src="/images/services_page/01_garden_view.webp" alt="Garden view at Pensión Agro da Porta" class="min-w-full object-cover aspect-video">
              <img src="/images/services_page/02_garden_view.webp" alt="Garden view at Pensión Agro da Porta" class="min-w-full object-cover aspect-video">
            </div>
            <button data-carousel-prev class="absolute left-2 top-1/2 -translate-y-1/2 flex h-8 w-8 items-center justify-center rounded-full bg-white/80 text-stone-800 shadow transition-colors hover:bg-white" aria-label="Previous image">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            </button>
            <button data-carousel-next class="absolute right-2 top-1/2 -translate-y-1/2 flex h-8 w-8 items-center justify-center rounded-full bg-white/80 text-stone-800 shadow transition-colors hover:bg-white" aria-label="Next image">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
            </button>
            <div class="absolute bottom-3 left-1/2 flex -translate-x-1/2 gap-2" data-carousel-dots>
              <button class="h-2 w-2 rounded-full bg-white transition-opacity" data-carousel-dot="0" aria-label="Image 1"></button>
              <button class="h-2 w-2 rounded-full bg-white/40 transition-opacity" data-carousel-dot="1" aria-label="Image 2"></button>
            </div>
          </div>
        </div>

        <div class="order-2">
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <article class="bg-amber-50 px-4 py-5 rounded-lg border border-amber-200 shadow-sm hover:shadow-md transition-shadow">
              <p class="text-2xl mb-3">🛏️</p>
              <h3 class="font-playfair text-xl text-stone-800">Comfortable Beds</h3>
              <p class="mt-3 font-lato text-sm leading-relaxed font-light text-stone-600">
                Clean, comfortable beds with quality linens so you can fully recover after each stage.
              </p>
            </article>

            <article class="bg-amber-50 px-4 py-5 rounded-lg border border-amber-200 shadow-sm hover:shadow-md transition-shadow">
              <p class="text-2xl mb-3">🚽</p>
              <h3 class="font-playfair text-xl text-stone-800">Private Bathroom</h3>
              <p class="mt-3 font-lato text-sm leading-relaxed font-light text-stone-600">
                Spacious bathrooms with reliable hot water and fresh towels available every day.
              </p>
            </article>

            <article class="bg-amber-50 px-4 py-5 rounded-lg border border-amber-200 shadow-sm hover:shadow-md transition-shadow">
              <p class="text-2xl mb-3">📶</p>
              <h3 class="font-playfair text-xl text-stone-800">Free Wi-Fi</h3>
              <p class="mt-3 font-lato text-sm leading-relaxed font-light text-stone-600">
                Stable internet in common areas and rooms to stay connected and plan your route.
              </p>
            </article>

            <article class="bg-amber-50 px-4 py-5 rounded-lg border border-amber-200 shadow-sm hover:shadow-md transition-shadow">
              <p class="text-2xl mb-3">🚴</p>
              <h3 class="font-playfair text-xl text-stone-800">Bicycle Parking</h3>
              <p class="mt-3 font-lato text-sm leading-relaxed font-light text-stone-600">
                Secure, sheltered parking for bicycles and bikes, perfect for cyclists on the Camino.
              </p>
            </article>

            <article class="bg-amber-50 px-4 py-5 rounded-lg border border-amber-200 shadow-sm hover:shadow-md transition-shadow">
              <p class="text-2xl mb-3">♿</p>
              <h3 class="font-playfair text-xl text-stone-800">Adapted Hotel</h3>
              <p class="mt-3 font-lato text-sm leading-relaxed font-light text-stone-600">
                Fully accessible facilities with adapted rooms and bathrooms for guests with mobility needs.
              </p>
            </article>

            <article class="bg-amber-50 px-4 py-5 rounded-lg border border-amber-200 shadow-sm hover:shadow-md transition-shadow">
              <p class="text-2xl mb-3">❄️</p>
              <h3 class="font-playfair text-xl text-stone-800">Climate Control</h3>
              <p class="mt-3 font-lato text-sm leading-relaxed font-light text-stone-600">
                Individual temperature control in each room so you can rest comfortably any season.
              </p>
            </article>

            <article class="bg-amber-50 px-4 py-5 rounded-lg border border-amber-200 shadow-sm hover:shadow-md transition-shadow">
              <p class="text-2xl mb-3">📺</p>
              <h3 class="font-playfair text-xl text-stone-800">Smart TV</h3>
              <p class="mt-3 font-lato text-sm leading-relaxed font-light text-stone-600">
                Modern entertainment with streaming services to relax and unwind after your day's walk.
              </p>
            </article>

            <article class="bg-amber-50 px-4 py-5 rounded-lg border border-amber-200 shadow-sm hover:shadow-md transition-shadow">
              <p class="text-2xl mb-3">🌳</p>
              <h3 class="font-playfair text-xl text-stone-800">Garden</h3>
              <p class="mt-3 font-lato text-sm leading-relaxed font-light text-stone-600">
                Peaceful outdoor space to relax, socialize with fellow pilgrims, and enjoy nature.
              </p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('[data-carousel]').forEach((carousel) => {
      const track = carousel.querySelector('[data-carousel-track]') as HTMLElement;
      const dots = carousel.querySelectorAll('[data-carousel-dot]') as NodeListOf<HTMLElement>;
      const total = track.children.length;
      let current = 0;

      function goTo(index: number) {
        current = ((index % total) + total) % total;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((dot, i) => {
          dot.style.opacity = i === current ? '1' : '0.4';
        });
      }

      carousel.querySelector('[data-carousel-prev]')?.addEventListener('click', () => goTo(current - 1));
      carousel.querySelector('[data-carousel-next]')?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
    });
  </script>

  <section class="bg-amber-50 px-4 py-16 sm:px-6 sm:py-20">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-2">
      <div class="border border-amber-200 bg-white p-6 sm:p-8">
        <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-700 sm:tracking-[0.3em]">Included</p>
        <h3 class="mt-3 font-playfair text-3xl text-stone-800">With Every Stay</h3>
        <ul class="mt-6 space-y-3 font-lato text-sm font-light text-stone-700">
          <li>Fresh bed linen and towels</li>
          <li>Heating in cooler months</li>
          <li>Secure backpack storage</li>
          <li>Charging points near beds</li>
          <li>Pilgrim stamp for your credential</li>
        </ul>
      </div>

      <div class="border border-[#5f3a24] bg-[#74462b] p-6 sm:p-8">
        <p class="font-lato text-xs uppercase tracking-[0.2em] text-amber-400 sm:tracking-[0.3em]">Helpful Extras</p>
        <h3 class="mt-3 font-playfair text-3xl text-amber-50">Available On Request</h3>
        <ul class="mt-6 space-y-3 font-lato text-sm font-light text-amber-100/80">
          <li>Taxi to nearby medical center</li>
          <li>Packed breakfast for very early starts</li>
          <li>Late check-in coordination</li>
          <li>Recommendations for local dinner menus</li>
          <li>Help with next-stage planning</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-[#74462b] px-4 py-16 text-center sm:px-6 sm:py-24">
    <div class="mx-auto max-w-2xl">
      <h2 class="font-playfair text-3xl text-amber-50 sm:text-4xl">Need Something Specific?</h2>
      <p class="mt-4 font-lato text-base font-light text-amber-100/80 sm:text-lg">
        Tell us what you need and we will do our best to make your stop comfortable.
      </p>
      <a
        href="/contact#contact-form"
        class="mt-8 inline-block w-full bg-amber-400 px-10 py-4 font-lato text-sm font-bold uppercase tracking-[0.14em] text-stone-900 transition-colors hover:bg-amber-300 sm:w-auto sm:tracking-widest"
      >
        Contact Us
      </a>
    </div>
  </section>
</BaseLayout>
