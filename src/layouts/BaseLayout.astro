---
const {
  title,
  description,
  lang = 'en',
} = Astro.props;
import '../styles/global.css';

const defaultTitle = lang === 'es'
  ? 'Pensión en Palas de Rei - Camino Francés'
  : 'Pensión in Palas de Rei - Camino Francés';
const defaultDescription = lang === 'es'
  ? 'Alojamiento para peregrinos en Palas de Rei, en el Camino de Santiago (Camino Francés).'
  : 'Accommodation for pilgrims in Palas de Rei on the Camino de Santiago (Camino Francés).';
const metaTitle = title ?? defaultTitle;
const metaDescription = description ?? defaultDescription;
const brandName = 'Pensión Agro da Porta';
const normalizedMetaTitle = metaTitle.trim();
const pageTitle = normalizedMetaTitle.toLowerCase().includes(brandName.toLowerCase())
  ? normalizedMetaTitle
  : `${normalizedMetaTitle} | ${brandName}`;

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isSpanish = lang === 'es';
const navBase = isSpanish ? '/es' : '';
const toLocalizedPath = (href: string) => {
  if (href === '/') return navBase || '/';
  return `${navBase}${href}`;
};
const isActive = (href: string) => {
  const localizedHref = toLocalizedPath(href);
  if (href === '/') return pathname === localizedHref;
  return pathname === localizedHref || pathname.startsWith(`${localizedHref}/`);
};

const englishPath = pathname.startsWith('/es') ? pathname.slice(3) || '/' : pathname;
const spanishPath = pathname.startsWith('/es')
  ? (pathname === '/es' ? '/es/' : pathname)
  : (pathname === '/' ? '/es/' : `/es${pathname}`);
const canonicalPath = pathname === '/es' ? '/es/' : pathname;

const toAbsoluteUrl = (path: string) => new URL(path, Astro.site ?? Astro.url).toString();
const canonicalUrl = toAbsoluteUrl(canonicalPath);
const englishAlternateUrl = toAbsoluteUrl(englishPath);
const spanishAlternateUrl = toAbsoluteUrl(spanishPath);
const xDefaultUrl = englishAlternateUrl;
const websiteUrl = toAbsoluteUrl('/');
const socialImageUrl = toAbsoluteUrl('/images/pension.webp');
const socialImageAlt = isSpanish
  ? 'Vista de Pensión Agro da Porta en Palas de Rei, Camino Francés'
  : 'View of Pensión Agro da Porta in Palas de Rei on Camino Francés';
const ogLocale = isSpanish ? 'es_ES' : 'en_US';
const ogLocaleAlternate = isSpanish ? 'en_US' : 'es_ES';
const mapsUrl = 'https://www.google.com/maps/place/Pensi%C3%B3n+Agro+da+Porta/@42.873017,-7.8671399,20z/data=!4m15!1m5!3m4!2zNDLCsDUyJzIyLjkiTiA3wrA1MicwMC41Ilc!8m2!3d42.873017!4d-7.866818!3m8!1s0xd2fd54482ef9e57:0x3496ffaddd4bf814!5m2!4m1!1i2!8m2!3d42.8729849!4d-7.8668177!16s%2Fg%2F11z9rsflnv?entry=ttu&g_ep=EgoyMDI2MDQyOS4wIKXMDSoASAFQAw%3D%3D';
const whatsappUrl = 'https://wa.me/34744251454';
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${websiteUrl}#website`,
  url: websiteUrl,
  name: brandName,
  inLanguage: ['en', 'es'],
};
const lodgingBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  '@id': `${websiteUrl}#lodging-business`,
  name: brandName,
  description: 'Pensión for pilgrims in Palas de Rei on the Camino de Santiago.',
  url: websiteUrl,
  image: toAbsoluteUrl('/images/pension.webp'),
  logo: toAbsoluteUrl('/favicon.svg'),
  priceRange: '€65-€100',
  telephone: '+34744251454',
  email: 'infoagrodaporta@gmail.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Rúa Cruceiro 13',
    addressLocality: 'Palas de Rei',
    addressRegion: 'Lugo',
    postalCode: '27200',
    addressCountry: 'ES',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 42.8729849,
    longitude: -7.8668177,
  },
  hasMap: mapsUrl,
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Palas de Rei, Lugo, Galicia, Spain',
  },
  inLanguage: ['en', 'es'],
  sameAs: [],
};
const structuredData = [websiteSchema, lodgingBusinessSchema];

const uiText = isSpanish
  ? {
      home: 'Inicio',
      rooms: 'Habitaciones',
      services: 'Servicios',
      book: 'Reservar',
      contact: 'Contacto',
      languageSwitch: 'Idioma',
      contactLabel: 'Contacto',
      directions: 'Obtener Indicaciones',
      whatsapp: 'WhatsApp',
      whatsappAriaLabel: 'Abrir chat por WhatsApp',
      followUs: 'Síguenos',
      rights: '(c) 2025 Pensión Agro da Porta. Todos los derechos reservados.',
      location: 'Rúa Cruceiro 13\nPalas de Rei (Lugo), Spain',
    }
  : {
      home: 'Home',
      rooms: 'Rooms',
      services: 'Services',
      book: 'Book',
      contact: 'Contact',
      languageSwitch: 'Language',
      contactLabel: 'Contact',
      directions: 'Get Directions',
      whatsapp: 'WhatsApp',
      whatsappAriaLabel: 'Open WhatsApp chat',
      followUs: 'Follow Us',
      rights: '(c) 2025 Pensión Agro da Porta. All rights reserved.',
      location: 'Rúa Cruceiro 13\nPalas de Rei (Lugo), Spain',
    };

---

<!doctype html>
<html lang={lang} class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="theme-color" content="#8b5a3c" />
    <title>{pageTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brandName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={englishAlternateUrl} />
    <link rel="alternate" hreflang="es" href={spanishAlternateUrl} />
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="m-0 overflow-x-hidden bg-stone-50 text-stone-800 font-lato">
    <header class="relative w-full bg-[#8b5a3c] px-3 py-3 text-amber-50 sm:px-4 sm:py-4">
      <nav class="flex w-full flex-col items-start gap-3 sm:flex-row sm:items-center sm:gap-3">
        <a
          href={toLocalizedPath('/')}
          class="font-playfair text-lg font-bold tracking-wide text-amber-400 transition-colors hover:text-amber-300 sm:ml-3 sm:text-2xl"
        >
          Pensión Agro da Porta
        </a>
        <ul class="flex w-full flex-nowrap items-center gap-x-2 pr-16 text-[11px] font-light uppercase tracking-[0.04em] sm:ml-16 sm:w-auto sm:gap-8 sm:pr-0 sm:text-sm sm:tracking-widest">
          <li>
            <a
              href={toLocalizedPath('/')}
              aria-current={isActive('/') ? 'page' : undefined}
              class={`block min-h-10 py-2 transition-colors hover:text-amber-400 ${isActive('/') ? 'text-amber-400 underline decoration-amber-400 underline-offset-2' : ''}`}
            >
              {uiText.home}
            </a>
          </li>
          <li>
            <a
              href={toLocalizedPath('/rooms')}
              aria-current={isActive('/rooms') ? 'page' : undefined}
              class={`block min-h-10 py-2 transition-colors hover:text-amber-400 ${isActive('/rooms') ? 'text-amber-400 underline decoration-amber-400 underline-offset-2' : ''}`}
            >
              {uiText.rooms}
            </a>
          </li>
          <li>
            <a
              href={toLocalizedPath('/services')}
              aria-current={isActive('/services') ? 'page' : undefined}
              class={`block min-h-10 py-2 transition-colors hover:text-amber-400 ${isActive('/services') ? 'text-amber-400 underline decoration-amber-400 underline-offset-2' : ''}`}
            >
              {uiText.services}
            </a>
          </li>
          <!-- Book page temporarily disabled -->
          <!--
          <li>
            <a
              href={toLocalizedPath('/booking')}
              aria-current={isActive('/booking') ? 'page' : undefined}
              class={`block py-1 transition-colors hover:text-amber-400 ${isActive('/booking') ? 'text-amber-400 underline decoration-amber-400 underline-offset-8' : ''}`}
            >
              {uiText.book}
            </a>
          </li>
          -->
          <li>
            <a
              href={toLocalizedPath('/contact')}
              aria-current={isActive('/contact') ? 'page' : undefined}
              class={`block min-h-10 py-2 transition-colors hover:text-amber-400 ${isActive('/contact') ? 'text-amber-400 underline decoration-amber-400 underline-offset-2' : ''}`}
            >
              {uiText.contact}
            </a>
          </li>
        </ul>

        <div class="absolute right-3 top-3 flex items-center gap-2 sm:static sm:ml-auto sm:mr-4">
          <span class="font-lato text-[8px] uppercase tracking-[0.18em] text-amber-200/80">{uiText.languageSwitch}</span>
          <div class="inline-flex overflow-hidden rounded border border-amber-300/60">
            <a
              href={englishPath}
              class={`px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] transition-colors ${!isSpanish ? 'bg-amber-400 text-stone-900' : 'text-amber-100 hover:bg-amber-400/20'}`}
              aria-label="Switch to English"
            >
              EN
            </a>
            <a
              href={spanishPath}
              class={`px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] transition-colors ${isSpanish ? 'bg-amber-400 text-stone-900' : 'text-amber-100 hover:bg-amber-400/20'}`}
              aria-label="Cambiar a español"
            >
              ES
            </a>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-16 bg-[#74462b] px-4 py-10 text-amber-100/80 sm:mt-20 sm:px-6">
      <div class="mx-auto flex max-w-5xl flex-col justify-between gap-8 text-sm md:flex-row">
        <div>
          <p class="mb-2 text-lg font-playfair font-semibold text-amber-400">Pensión Agro da Porta</p>
          <p class="whitespace-pre-line">{uiText.location}</p>
          <a
            href={mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-flex items-center gap-2 font-lato text-xs font-bold uppercase tracking-[0.14em] text-amber-300 transition-colors hover:text-amber-200 sm:text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M10 2a6 6 0 00-6 6c0 4.79 5.23 9.48 5.45 9.68a.75.75 0 001.1 0C10.77 17.48 16 12.79 16 8a6 6 0 00-6-6zm0 8.5A2.5 2.5 0 1112.5 8 2.5 2.5 0 0110 10.5z"/>
            </svg>
            {uiText.directions}
          </a>
        </div>
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-amber-200/80">{uiText.contactLabel}</p>
          <p>
            <a href="mailto:infoagrodaporta@gmail.com" class="transition-colors hover:text-amber-200">
              infoagrodaporta@gmail.com
            </a>
          </p>
          <p>
            <a href="tel:+34744251454" class="transition-colors hover:text-amber-200">
              +34 744 25 14 54
            </a>
          </p>
          <p class="mt-2">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={uiText.whatsappAriaLabel}
              class="inline-flex items-center gap-2 text-amber-100 transition-colors hover:text-amber-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true">
                <path d="M12 2a10 10 0 00-8.7 14.93L2 22l5.22-1.27A10 10 0 1012 2zm0 18a8 8 0 01-4.07-1.11l-.29-.17-3.1.75.83-3.02-.19-.31A8 8 0 1112 20zm4.39-5.61c-.24-.12-1.43-.71-1.65-.79-.22-.08-.38-.12-.54.12-.16.24-.62.79-.76.95-.14.16-.28.18-.52.06-.24-.12-1.02-.38-1.95-1.2-.72-.64-1.2-1.43-1.34-1.67-.14-.24-.01-.37.11-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.2-.47-.4-.41-.54-.42h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.31.98 2.47c.12.16 1.69 2.58 4.1 3.62.57.25 1.02.4 1.37.51.58.18 1.11.15 1.53.09.47-.07 1.43-.58 1.63-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28z"/>
              </svg>
              {uiText.whatsapp}
            </a>
          </p>
        </div>
        {/* Social networks — uncomment when accounts are ready
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-amber-200/80">{uiText.followUs}</p>
          <p>Instagram</p>
          <p>Facebook</p>
        </div>
        */}
      </div>
      <p class="mt-8 text-center text-[11px] text-amber-200/50 sm:text-xs">{uiText.rights}</p>
    </footer>
  </body>
</html>
