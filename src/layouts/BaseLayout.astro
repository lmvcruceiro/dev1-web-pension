---
const {
  title = "Pension Palas",
  description = "A warm albergue on the Camino de Santiago",
} = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Pension Palas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-stone-50 text-stone-800 font-lato">
    <header class="w-full bg-stone-900 px-6 py-4 text-stone-100">
      <nav class="mx-auto flex max-w-5xl items-center justify-between">
        <a
          href="/"
          class="font-playfair text-2xl font-bold tracking-wide text-amber-400 transition-colors hover:text-amber-300"
        >
          Pension Palas
        </a>
        <ul class="flex gap-8 text-sm font-light uppercase tracking-widest">
          <li><a href="/" class="transition-colors hover:text-amber-400">Home</a></li>
          <li><a href="/services" class="transition-colors hover:text-amber-400">Services</a></li>
          <li><a href="/contact" class="transition-colors hover:text-amber-400">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-20 bg-stone-900 px-6 py-10 text-stone-400">
      <div class="mx-auto flex max-w-5xl flex-col justify-between gap-6 text-sm md:flex-row">
        <div>
          <p class="mb-2 text-lg font-playfair font-semibold text-amber-400">Pension Palas</p>
          <p>Camino de Santiago</p>
          <p>Espana</p>
        </div>
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-stone-300">Contact</p>
          <p>info@pensionpalas.com</p>
          <p>+34 000 000 000</p>
        </div>
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-stone-300">Follow Us</p>
          <p>Instagram</p>
          <p>Facebook</p>
        </div>
      </div>
      <p class="mt-8 text-center text-xs text-stone-600">(c) 2025 Pension Palas. All rights reserved.</p>
    </footer>
  </body>
</html>
