---
const {
  title = "Pensión Agro da Porta",
  description = "A warm albergue on the Camino de Santiago",
  lang = 'en',
} = Astro.props;
import '../styles/global.css';

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isSpanish = lang === 'es';
const navBase = isSpanish ? '/es' : '';
const toLocalizedPath = (href: string) => {
  if (href === '/') return navBase || '/';
  return `${navBase}${href}`;
};
const isActive = (href: string) => {
  const localizedHref = toLocalizedPath(href);
  if (localizedHref === '/') return pathname === '/';
  return pathname === localizedHref || pathname.startsWith(`${localizedHref}/`);
};

const englishPath = pathname.startsWith('/es') ? pathname.slice(3) || '/' : pathname;
const spanishPath = pathname.startsWith('/es')
  ? (pathname === '/es' ? '/es/' : pathname)
  : (pathname === '/' ? '/es/' : `/es${pathname}`);

const uiText = isSpanish
  ? {
      home: 'Inicio',
      rooms: 'Habitaciones',
      services: 'Servicios',
      book: 'Reservar',
      contact: 'Contacto',
      languageSwitch: 'Idioma',
      contactLabel: 'Contacto',
      followUs: 'Síguenos',
      rights: '(c) 2025 Pensión Agro da Porta. Todos los derechos reservados.',
      location: 'Palas de Rei, Galicia, España',
    }
  : {
      home: 'Home',
      rooms: 'Rooms',
      services: 'Services',
      book: 'Book',
      contact: 'Contact',
      languageSwitch: 'Language',
      contactLabel: 'Contact',
      followUs: 'Follow Us',
      rights: '(c) 2025 Pensión Agro da Porta. All rights reserved.',
      location: 'Palas de Rei, Galicia, Spain',
    };
---

<!doctype html>
<html lang={lang} class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Pensión Agro da Porta</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="m-0 overflow-x-hidden bg-stone-50 text-stone-800 font-lato">
    <header class="relative w-full bg-[#8b5a3c] px-3 py-3 text-amber-50 sm:px-4 sm:py-4">
      <nav class="flex w-full flex-col items-start gap-3 sm:flex-row sm:items-center sm:gap-3">
        <a
          href={toLocalizedPath('/')}
          class="font-playfair text-lg font-bold tracking-wide text-amber-400 transition-colors hover:text-amber-300 sm:ml-3 sm:text-2xl"
        >
          Pensión Agro da Porta
        </a>
        <ul class="flex w-full flex-wrap gap-x-4 gap-y-2 pr-20 text-xs font-light uppercase tracking-[0.08em] sm:ml-16 sm:w-auto sm:gap-8 sm:pr-0 sm:text-sm sm:tracking-widest">
          <li>
            <a
              href={toLocalizedPath('/')}
              aria-current={isActive('/') ? 'page' : undefined}
              class={`block min-h-10 py-2 transition-colors hover:text-amber-400 ${isActive('/') ? 'text-amber-400 underline decoration-amber-400 underline-offset-4' : ''}`}
            >
              {uiText.home}
            </a>
          </li>
          <li>
            <a
              href={toLocalizedPath('/rooms')}
              aria-current={isActive('/rooms') ? 'page' : undefined}
              class={`block min-h-10 py-2 transition-colors hover:text-amber-400 ${isActive('/rooms') ? 'text-amber-400 underline decoration-amber-400 underline-offset-4' : ''}`}
            >
              {uiText.rooms}
            </a>
          </li>
          <li>
            <a
              href={toLocalizedPath('/services')}
              aria-current={isActive('/services') ? 'page' : undefined}
              class={`block min-h-10 py-2 transition-colors hover:text-amber-400 ${isActive('/services') ? 'text-amber-400 underline decoration-amber-400 underline-offset-4' : ''}`}
            >
              {uiText.services}
            </a>
          </li>
          <!-- Book page temporarily disabled -->
          <!--
          <li>
            <a
              href={toLocalizedPath('/booking')}
              aria-current={isActive('/booking') ? 'page' : undefined}
              class={`block py-1 transition-colors hover:text-amber-400 ${isActive('/booking') ? 'text-amber-400 underline decoration-amber-400 underline-offset-8' : ''}`}
            >
              {uiText.book}
            </a>
          </li>
          -->
          <li>
            <a
              href={toLocalizedPath('/contact')}
              aria-current={isActive('/contact') ? 'page' : undefined}
              class={`block min-h-10 py-2 transition-colors hover:text-amber-400 ${isActive('/contact') ? 'text-amber-400 underline decoration-amber-400 underline-offset-4' : ''}`}
            >
              {uiText.contact}
            </a>
          </li>
        </ul>

        <div class="absolute right-3 top-3 flex items-center gap-2 sm:static sm:ml-auto sm:mr-4">
          <span class="font-lato text-[10px] uppercase tracking-[0.18em] text-amber-200/80">{uiText.languageSwitch}</span>
          <div class="inline-flex overflow-hidden rounded border border-amber-300/60">
            <a
              href={englishPath}
              class={`px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] transition-colors ${!isSpanish ? 'bg-amber-400 text-stone-900' : 'text-amber-100 hover:bg-amber-400/20'}`}
              aria-label="Switch to English"
            >
              EN
            </a>
            <a
              href={spanishPath}
              class={`px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] transition-colors ${isSpanish ? 'bg-amber-400 text-stone-900' : 'text-amber-100 hover:bg-amber-400/20'}`}
              aria-label="Cambiar a español"
            >
              ES
            </a>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-16 bg-[#74462b] px-4 py-10 text-amber-100/80 sm:mt-20 sm:px-6">
      <div class="mx-auto flex max-w-5xl flex-col justify-between gap-8 text-sm md:flex-row">
        <div>
          <p class="mb-2 text-lg font-playfair font-semibold text-amber-400">Pensión Agro da Porta</p>
          <p>{uiText.location}</p>
        </div>
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-amber-200/80">{uiText.contactLabel}</p>
          <p>infoagrodaporta@gmail.com</p>
          <p>+34 744 25 14 54</p>
        </div>
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-amber-200/80">{uiText.followUs}</p>
          <p>Instagram</p>
          <p>Facebook</p>
        </div>
      </div>
      <p class="mt-8 text-center text-[11px] text-amber-200/50 sm:text-xs">{uiText.rights}</p>
    </footer>
  </body>
</html>
