---
const {
  title = "Pensión Agro da Porta",
  description = "A warm albergue on the Camino de Santiago",
} = Astro.props;
import '../styles/global.css';

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href) => {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<!doctype html>
<html lang="en" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Pensión Agro da Porta</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="m-0 overflow-x-hidden bg-stone-50 text-stone-800 font-lato">
    <header class="w-full bg-stone-900 px-4 py-4 text-stone-100 sm:px-6">
      <nav class="mx-auto flex max-w-5xl flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
        <a
          href="/"
          class="font-playfair text-xl font-bold tracking-wide text-amber-400 transition-colors hover:text-amber-300 sm:text-2xl"
        >
          Pensión Agro da Porta
        </a>
        <ul class="flex w-full flex-wrap gap-x-5 gap-y-2 text-xs font-light uppercase tracking-[0.08em] sm:w-auto sm:gap-8 sm:text-sm sm:tracking-widest">
          <li>
            <a
              href="/"
              aria-current={isActive('/') ? 'page' : undefined}
              class={`block py-1 transition-colors hover:text-amber-400 ${isActive('/') ? 'text-amber-400 underline decoration-amber-400 underline-offset-8' : ''}`}
            >
              Home
            </a>
          </li>
          <li>
            <a
              href="/rooms"
              aria-current={isActive('/rooms') ? 'page' : undefined}
              class={`block py-1 transition-colors hover:text-amber-400 ${isActive('/rooms') ? 'text-amber-400 underline decoration-amber-400 underline-offset-8' : ''}`}
            >
              Rooms
            </a>
          </li>
          <li>
            <a
              href="/services"
              aria-current={isActive('/services') ? 'page' : undefined}
              class={`block py-1 transition-colors hover:text-amber-400 ${isActive('/services') ? 'text-amber-400 underline decoration-amber-400 underline-offset-8' : ''}`}
            >
              Services
            </a>
          </li>
          <li>
            <a
              href="/booking"
              aria-current={isActive('/booking') ? 'page' : undefined}
              class={`block py-1 transition-colors hover:text-amber-400 ${isActive('/booking') ? 'text-amber-400 underline decoration-amber-400 underline-offset-8' : ''}`}
            >
              Book
            </a>
          </li>
          <li>
            <a
              href="/contact"
              aria-current={isActive('/contact') ? 'page' : undefined}
              class={`block py-1 transition-colors hover:text-amber-400 ${isActive('/contact') ? 'text-amber-400 underline decoration-amber-400 underline-offset-8' : ''}`}
            >
              Contact
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-16 bg-stone-900 px-4 py-10 text-stone-400 sm:mt-20 sm:px-6">
      <div class="mx-auto flex max-w-5xl flex-col justify-between gap-8 text-sm md:flex-row">
        <div>
          <p class="mb-2 text-lg font-playfair font-semibold text-amber-400">Pensión Agro da Porta</p>
          <p>Camino de Santiago</p>
          <p>Espana</p>
        </div>
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-stone-300">Contact</p>
          <p>infoagrodaporta@gmail.com</p>
          <p>+34 744 25 14 54</p>
        </div>
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-stone-300">Follow Us</p>
          <p>Instagram</p>
          <p>Facebook</p>
        </div>
      </div>
      <p class="mt-8 text-center text-[11px] text-stone-600 sm:text-xs">(c) 2025 Pensión Agro da Porta. All rights reserved.</p>
    </footer>
  </body>
</html>
